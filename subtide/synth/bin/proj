#!/usr/bin/env bb

(ns proj
  (:require
   [lioss.main :as lioss]
   [clojure.string :as str]))

(defn update-version-file [conf]
  (let [[major minor teeny] (map parse-long (str/split (:version conf) #"\."))]
    (spit
     "src/subtide/version.clj"
     (str/replace
      (slurp "src/subtide/version.clj")
      #"\(def SUBTIDE-VERSION .*\)"
      (pr-str
       `(~'def ~'SUBTIDE-VERSION {:major ~major :minor ~minor :patch ~teeny :snapshot false})))))
  conf)

(lioss/main
 {:license        :mit
  :group-id       "org.subtide"
  :gh-project     "subtide/subtide"
  :org-name       "Subtide"
  :org-url        "https://subtide.org"
  :inception-year 2026
  :description    "Sound and music live programming environment."
  :pre-release-hook update-version-file
  :commands ["update-version-file"
             {:description "Store the current version in subtide/version.clj"
              :command update-version-file}]})
